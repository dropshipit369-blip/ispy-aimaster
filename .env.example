# =====================================================
# SUPABASE FRONTEND CONFIGURATION
# =====================================================
# Get these from https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_SUPABASE_URL=https://your_project.supabase.co

# =====================================================
# STRIPE PAYMENT PROCESSING
# =====================================================
# Get these from https://dashboard.stripe.com/apikeys

# Publishable key for frontend Stripe.js integrations
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx_or_pk_live_xxxxxxxxxxxx

# Secret key for server-side operations (Supabase edge functions)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx_or_sk_live_xxxxxxxxxxxx

# Webhook secret for receiving Stripe events
# Generate this in Stripe Dashboard > Webhooks after deploying stripe-webhook function
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Price IDs for subscription plans (create in Stripe Dashboard > Products)
# Pro Plan: $19/month
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxx

# Unlimited Plan: $49/month
STRIPE_UNLIMITED_PRICE_ID=price_xxxxxxxxxxxx

# =====================================================
# SUPABASE EDGE FUNCTIONS (Server-side)
# =====================================================
# These are automatically set by Supabase for edge functions

# SUPABASE_URL=https://your_project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# =====================================================
# OPTIONAL: AI/LLM APIS
# =====================================================

# Gemini API for Vision+ and pricing strategy
GEMINI_API_KEY=your_gemini_api_key

# Lovable AI Gateway for image analysis
LOVABLE_API_KEY=your_lovable_api_key

# ScrapingBee for verified eBay sold-listing scraping via residential proxies
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key

# OpenRouter — final fallback so a scan/pricing call always returns output
# even when every Gemini model is rate-limited or unavailable.
# Get a key at https://openrouter.ai/keys (free-tier models cost $0).
OPENROUTER_API_KEY=your_openrouter_api_key
# Optional model overrides (defaults shown are free-tier):
# OPENROUTER_VISION_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free
# OPENROUTER_TEXT_MODEL=meta-llama/llama-3.3-70b-instruct:free
